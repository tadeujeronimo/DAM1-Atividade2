<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fundo"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/header_bg" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧮 Operações Matemáticas"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Operação"
                android:textSize="13sp"
                android:textColor="@color/texto_hint"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerOperacao"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Número 1"
                android:textSize="13sp"
                android:textColor="@color/texto_hint"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/editNum1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:hint="Ex: 10"
                android:background="@null"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/texto_hint"
                android:paddingBottom="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vermelho"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/labelNum2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Número 2"
                android:textSize="13sp"
                android:textColor="@color/texto_hint"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/editNum2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:hint="Ex: 5"
                android:background="@null"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/texto_hint"
                android:paddingBottom="8dp"/>

            <View
                android:id="@+id/dividerNum2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vermelho"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnCalcular"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Calcular"
                android:textSize="16sp"
                android:textColor="@color/branco"
                android:background="@drawable/btn_vermelho"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnVoltar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Voltar"
                android:textSize="15sp"
                android:textColor="@color/vermelho"
                android:background="@drawable/btn_outline"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
