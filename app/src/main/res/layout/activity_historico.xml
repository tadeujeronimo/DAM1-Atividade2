<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/historico_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fundo"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/header_bg" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📜 Histórico"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/txtVazio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Nenhuma conversa ainda.\nEnvie uma mensagem ao Marciano!"
        android:textSize="15sp"
        android:textColor="@color/texto_hint"
        android:gravity="center"
        android:visibility="gone"/>

    <ListView
        android:id="@+id/listHistorico"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:divider="@color/divisor"
        android:dividerHeight="1dp"/>

    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginVertical="16dp"
        android:text="Voltar"
        android:textSize="16sp"
        android:textColor="@color/branco"
        android:background="@drawable/btn_vermelho"/>

</LinearLayout>
