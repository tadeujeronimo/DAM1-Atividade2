<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fundo"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/header_bg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 Robô Marciano 👽"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="8dp"
            android:gravity="top">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Olá, eu sou o Robô Marciano.\nVocê pode me perguntar qualquer coisa.\nDigite a sua mensagem abaixo:"
                android:textSize="15sp"
                android:textColor="@color/texto_principal"
                android:textAlignment="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"/>

            <EditText
                android:id="@+id/editMensagem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Digite sua mensagem..."
                android:inputType="textMultiLine"
                android:minLines="1"
                android:maxLines="4"
                android:background="@null"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/texto_hint"
                android:textSize="15sp"
                android:paddingBottom="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vermelho"
                android:layout_marginBottom="28dp"/>

            <Button
                android:id="@+id/btnEnviar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Enviar"
                android:textSize="16sp"
                android:textColor="@color/branco"
                android:background="@drawable/btn_vermelho"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnMatematica"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Operações Matemáticas"
                android:textSize="15sp"
                android:textColor="@color/vermelho"
                android:background="@drawable/btn_outline"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnHistorico"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Ver Histórico"
                android:textSize="15sp"
                android:textColor="@color/vermelho"
                android:background="@drawable/btn_outline"/>

        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_dialog_info"
        app:tint="@color/vermelho"
        android:contentDescription="Informações do Desenvolvedor" />

</FrameLayout>
