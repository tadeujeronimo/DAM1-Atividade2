<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fundo principal do header -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#EDEBE8"/>
        </shape>
    </item>
    <!-- Círculo grande vermelho no canto superior esquerdo -->
    <item
        android:top="-80dp"
        android:left="-80dp"
        android:right="200dp"
        android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="#E07070"/>
        </shape>
    </item>
    <!-- Círculo menor vermelho sobreposto -->
    <item
        android:top="40dp"
        android:left="-40dp"
        android:right="260dp"
        android:bottom="-40dp">
        <shape android:shape="oval">
            <solid android:color="#CC5C5C"/>
        </shape>
    </item>
</layer-list>
